<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>香港快閃導覽</name>
  <description>兩天一夜快閃地圖，住九龍酒店（尖沙咀）</description>

  <!-- 分類樣式 -->
  <Style id="food">
    <IconStyle><color>ff2222cc</color><Icon><href>http://maps.google.com/mapfiles/kml/paddle/red-circle.png</href></Icon></IconStyle>
  </Style>
  <Style id="sight">
    <IconStyle><color>ff22cc22</color><Icon><href>http://maps.google.com/mapfiles/kml/paddle/grn-circle.png</href></Icon></IconStyle>
  </Style>
  <Style id="shop">
    <IconStyle><color>ffcc8822</color><Icon><href>http://maps.google.com/mapfiles/kml/paddle/ylw-circle.png</href></Icon></IconStyle>
  </Style>
  <Style id="cafe">
    <IconStyle><color>ffcc22aa</color><Icon><href>http://maps.google.com/mapfiles/kml/paddle/pink-circle.png</href></Icon></IconStyle>
  </Style>
  <Style id="hotel">
    <IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/blu-circle.png</href></Icon></IconStyle>
  </Style>

  <!-- 住宿 -->
  <Folder><name>🏨 住宿</name>
    <Placemark>
      <name>香港九龍酒店（住宿）</name>
      <description>19-21 Nathan Road, 油尖旺區｜地鐵尖沙咀站步行2分鐘</description>
      <styleUrl>#hotel</styleUrl>
      <Point><coordinates>114.1722,22.2988,0</coordinates></Point>
    </Placemark>
  </Folder>

  <!-- 尖沙咀 -->
  <Folder><name>📍 尖沙咀</name>
    <Placemark>
      <name>維多利亞港</name>
      <description>景點｜夜景必去，從酒店步行可達</description>
      <styleUrl>#sight</styleUrl>
