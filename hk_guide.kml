      <Point><coordinates>114.1683,22.2999,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>華嫂冰室（尖沙咀）</name>
      <description>美食｜菠蘿包超好吃</description>
      <styleUrl>#food</styleUrl>
      <Point><coordinates>114.1740,22.2982,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>一樂燒鵝</name>
      <description>美食｜要排隊，沾醬必點</description>
      <styleUrl>#food</styleUrl>
      <Point><coordinates>114.1718,22.2957,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Bakehouse（尖沙咀）</name>
      <description>甜點｜蛋撻名店</description>
      <styleUrl>#cafe</styleUrl>
      <Point><coordinates>114.1726,22.2969,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>泰昌蛋塔（尖沙咀）</name>
      <description>甜點</description>
      <styleUrl>#cafe</styleUrl>
      <Point><coordinates>114.1730,22.2975,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Shake Shack（尖沙咀）</name>
      <description>美食</description>
      <styleUrl>#food</styleUrl>
      <Point><coordinates>114.1680,22.2997,0</coordinates></Point>
